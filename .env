# ─── Claude API (optional — only used for CAPTCHA if CAPTCHA_MODE=claude) ───
ANTHROPIC_API_KEY=sk-ant-PASTEYOURKEY
ANTHROPIC_MODEL=claude-sonnet-4-6

# ─── IRCTC login ───
IRCTC_USERNAME=Name
IRCTC_PASSWORD=pswd

# ─── Journey details ───
IRCTC_FROM_STATION=CBE
IRCTC_FROM_NAME=Coimbatore Junction - CBE
IRCTC_TO_STATION=MAS
IRCTC_TO_NAME=MGR CHENNAI CENTRAL - MAS
# DD/MM/YYYY — leave empty to use today + offset days
IRCTC_JOURNEY_DATE=
# Days after today when IRCTC_JOURNEY_DATE is empty (2 = day after tomorrow)
IRCTC_JOURNEY_DATE_OFFSET_DAYS=6
IRCTC_CLASS=SL
# Leave empty for first available train; if set but not found, first train is used
IRCTC_PREFERRED_TRAIN=

# ─── Payment ───
# IRCTC_IPAY (default) or UPI
IRCTC_PAYMENT_METHOD=IRCTC_IPAY
# Gateway provider on final page: Paytm, PhonePe, etc.
IRCTC_PAYMENT_PROVIDER=Paytm

# ─── Contact ───
IRCTC_MOBILE=1234567892

# ─── Passengers (up to 6) ───
IRCTC_PASSENGER_COUNT=1
IRCTC_P1_NAME=Your Name
IRCTC_P1_AGE=24
IRCTC_P1_GENDER=Female
IRCTC_P1_BERTH=Side Lower
# IRCTC_P2_NAME=
# IRCTC_P2_AGE=
# IRCTC_P2_GENDER=Female
# IRCTC_P2_BERTH=Lower

# ─── Automation behaviour ───
# playwright = selector automation (default) | cdp = legacy vision/CDP agent
IRCTC_ENGINE=playwright
# manual = type CAPTCHA in UI/terminal | terminal = stdin only | claude = Claude reads captcha
CAPTCHA_MODE=manual
# false = visible Chrome (required for IRCTC)
HEADLESS=false
# false = automate payment flow (UPI OTP still manual in browser)
STOP_BEFORE_PAYMENT=false
# Login only
LOGIN_ONLY=false
# Keep session alive after login (seconds), 0 = skip (only used when LOGIN_ONLY=true)
KEEP_ALIVE_SECONDS=120

# Ignore SSL cert errors for gov portals (e.g. ttdsevaonline.com ERR_CERT_DATE_INVALID)
PLAYWRIGHT_IGNORE_HTTPS_ERRORS=true
